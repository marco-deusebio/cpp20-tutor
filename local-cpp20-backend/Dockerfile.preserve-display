    )

    code = re.sub(
        r'std::lcm\s*\(\s*(?P<a>[^,\n]+?)\s*,\s*(?P<b>[^;\n]+?)\s*\)',
        lambda m: '__cpp_tutor_lcm(%s, %s)' % (m.group('a'), m.group('b')),
        code
    )

    code = re.sub(
        r'std::reduce\s*\(',
        'std::accumulate(',
        code
    )

    code = re.sub(
        r'auto\s+(?P<name>[A-Za-z_]\w*)\s*=\s*std::ranges::remove\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<value>[^;\n]+?)\s*\)\s*;',
        lambda m: 'auto %s = std::remove(%s.begin(), %s.end(), %s);' % (
            m.group('name'), m.group('c'), m.group('c'), m.group('value')
        ),
        code
    )

    code = re.sub(
        r'auto\s+(?P<name>[A-Za-z_]\w*)\s*=\s*std::ranges::remove_if\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<pred>(?:\[[^\]]*\]\s*\([^)]*\)\s*\{[^}]*\}|[^)\n]+))\s*\)\s*;',
        lambda m: 'auto %s = std::remove_if(%s.begin(), %s.end(), %s);' % (
            m.group('name'), m.group('c'), m.group('c'), m.group('pred')
        ),
        code
    )

    code = re.sub(
        r'(?P<c>[A-Za-z_]\w*)\.erase\s*\(\s*(?P<it>[A-Za-z_]\w*)\.begin\s*\(\s*\)\s*,\s*(?P=it)\.end\s*\(\s*\)\s*\)\s*;',
        lambda m: '%s.erase(%s, %s.end());' % (m.group('c'), m.group('it'), m.group('c')),
        code
    )

    code = re.sub(
        r'std::popcount\s*\(\s*(?P<v>[^)\n]+?)\s*\)',
        lambda m: '__builtin_popcount(%s)' % m.group('v'),
        code
    )

    code = re.sub(
        r'std::has_single_bit\s*\(\s*(?P<v>[^)\n]+?)\s*\)',
        lambda m: '((%s) != 0 && (((%s) & ((%s) - 1)) == 0))' % (
            m.group('v'), m.group('v'), m.group('v')
        ),
        code
    )

    code = re.sub(
        r'std::bit_width\s*\(\s*(?P<v>[^)\n]+?)\s*\)',
        lambda m: '__cpp_tutor_bit_width(%s)' % m.group('v'),
        code
    )

    code = re.sub(
        r'std::bit_floor\s*\(\s*(?P<v>[^)\n]+?)\s*\)',
