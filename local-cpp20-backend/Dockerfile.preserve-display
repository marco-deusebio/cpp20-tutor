unsigned long long __cpp_tutor_bit_floor(T value) {
    unsigned long long x = static_cast<unsigned long long>(value);
    if (x == 0) {
        return 0;
    }
    return 1ULL << (__cpp_tutor_bit_width(x) - 1);
