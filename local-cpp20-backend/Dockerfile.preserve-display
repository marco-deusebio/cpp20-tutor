        code
    )

    code = re.sub(
        r'std::bit_ceil\s*\(\s*(?P<v>[^)\n]+?)\s*\)',
        lambda m: '__cpp_tutor_bit_ceil(%s)' % m.group('v'),
        code
    )

    code = re.sub(
        r'(?P<obj>\b[A-Za-z_]\w*)\.contains\s*\(\s*(?P<key>(?!"[^"]*")[^)\n]+)\)',
        lambda m: '(%s.find(%s) != %s.end())' % (m.group('obj'), m.group('key'), m.group('obj')),
        code
    )

    code = re.sub(
        r'std::erase\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<value>[^;\n]+?)\s*\)\s*;',
        lambda m: '%s.erase(std::remove(%s.begin(), %s.end(), %s), %s.end());' % (
            m.group('c'), m.group('c'), m.group('c'), m.group('value'), m.group('c')
        ),
        code
    )

    code = re.sub(
        r'std::erase_if\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<pred>(?:\[[^\]]*\]\s*\([^)]*\)\s*\{[^}]*\}|[^\n]+))\s*\)\s*;',
        lambda m: '%s.erase(std::remove_if(%s.begin(), %s.end(), %s), %s.end());' % (
            m.group('c'), m.group('c'), m.group('c'), m.group('pred'), m.group('c')
        ),
        code
    )

    return code


def cmp_helper_source():
