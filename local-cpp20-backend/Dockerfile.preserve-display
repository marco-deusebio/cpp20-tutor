    code = re.sub(
        r'std::ranges::max\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*\)',
        lambda m: '(*std::max_element(%s.begin(), %s.end()))' % (m.group('c'), m.group('c')),
        code
    )

    return code


def rewrite_iota_view_for_loops(code):
    pattern = re.compile(
        r'^(?P<indent>\s*)for\s*\(\s*'
        r'(?P<type>(?:int|long|long long|size_t|auto))\s+'
        r'(?P<name>[A-Za-z_]\w*)\s*:\s*'
        r'std::views::iota\s*\(\s*(?P<start>[^,\n]+?)\s*,\s*(?P<stop>[^)\n]+?)\s*\)\s*'
        r'\)\s*(?P<brace>\{?)\s*(?P<tail>//.*)?(?P<nl>\r?\n?)$',
        re.MULTILINE
    )

    def repl(match):
        indent = match.group('indent')
        typ = match.group('type')
        name = match.group('name')
        start = match.group('start')
        stop = match.group('stop')
        brace = match.group('brace')
        tail = match.group('tail') or ''
        nl = match.group('nl') or '\n'
        return '%sfor (%s %s = %s; %s < %s; ++%s)%s%s%s' % (
            indent, typ, name, start, name, stop, name,
            ' {' if brace else '',
            (' ' + tail) if tail else '',
            nl
        )

    return pattern.sub(repl, code)


def rewrite_reverse_view_for_loops(code):
    lines = code.splitlines(True)
    out = []
    counter = 0

    pattern = re.compile(
        r'^(?P<indent>\s*)for\s*\(\s*'
        r'(?P<type>(?:auto|int|long|long long|size_t|[A-Za-z_]\w*(?:::[A-Za-z_]\w*)?))\s+'
        r'(?P<name>[A-Za-z_]\w*)\s*:\s*'
        r'(?:(?:std::views::reverse\s*\(\s*(?P<c1>[A-Za-z_]\w*)\s*\))|(?:(?P<c2>[A-Za-z_]\w*)\s*\|\s*std::views::reverse))\s*'
        r'\)\s*(?P<brace>\{?)\s*(?P<tail>//.*)?(?P<nl>\r?\n?)$'
    )

    for line in lines:
        match = pattern.match(line)

        if not match:
            out.append(line)
            continue

        counter += 1
        indent = match.group('indent')
        typ = match.group('type')
        name = match.group('name')
        container = match.group('c1') or match.group('c2')
        brace = match.group('brace')
        tail = match.group('tail') or ''
        nl = match.group('nl') or '\n'
        it_name = '__cpp_tutor_reverse_it_%d' % counter

        declaration = '%s %s = *%s;' % (typ, name, it_name)

        if brace:
            out.append('%sfor (auto %s = %s.rbegin(); %s != %s.rend(); ++%s) { %s%s%s' % (
                indent, it_name, container, it_name, container, it_name,
                declaration, (' ' + tail) if tail else '', nl
            ))
        else:
            out.append('%sfor (auto %s = %s.rbegin(); %s != %s.rend(); ++%s)%s%s' % (
                indent, it_name, container, it_name, container, it_name,
                (' ' + tail) if tail else '', nl
            ))
            out.append('%s  %s%s' % (indent, declaration, nl))

    return ''.join(out)


def rewrite_filter_transform_view_for_loops(code):
    lines = code.splitlines(True)
    out = []
    counter = 0
    loop_type = r'(?:const\s+)?(?:auto|int|long|long long|size_t|[A-Za-z_]\w*(?:::[A-Za-z_]\w*)?)(?:\s*[&*])?'
    lambda_expr = r'\[[^\]]*\]\s*\([^)]*\)\s*(?:mutable\s*)?\{[^}]*\}'

    pattern = re.compile(
        r'^(?P<indent>\s*)for\s*\(\s*'
        r'(?P<type>' + loop_type + r')\s+'
        r'(?P<name>[A-Za-z_]\w*)\s*:\s*'
        r'(?:(?:std::views::(?P<kind1>filter|transform)\s*\(\s*(?P<c1>[A-Za-z_]\w*)\s*,\s*(?P<fn1>' + lambda_expr + r')\s*\))|'
        r'(?:(?P<c2>[A-Za-z_]\w*)\s*\|\s*std::views::(?P<kind2>filter|transform)\s*\(\s*(?P<fn2>' + lambda_expr + r')\s*\)))\s*'
        r'\)\s*(?P<brace>\{)\s*(?P<tail>//.*)?(?P<nl>\r?\n?)$'
    )

    for line in lines:
        match = pattern.match(line)

        if not match:
            out.append(line)
            continue

        counter += 1
        indent = match.group('indent')
        typ = match.group('type')
        name = match.group('name')
        kind = match.group('kind1') or match.group('kind2')
        container = match.group('c1') or match.group('c2')
        function = match.group('fn1') or match.group('fn2')
        tail = match.group('tail') or ''
        nl = match.group('nl') or '\n'

        if kind == 'filter':
            out.append('%sfor (%s %s : %s) { if (!(%s)(%s)) continue;%s%s' % (
                indent, typ, name, container, function, name,
                (' ' + tail) if tail else '', nl
            ))
        else:
            raw_name = '__cpp_tutor_transform_value_%d' % counter
            declaration = '%s %s = (%s)(%s);' % (typ, name, function, raw_name)
            out.append('%sfor (auto %s : %s) { %s%s%s' % (
                indent, raw_name, container, declaration,
                (' ' + tail) if tail else '', nl
            ))

    return ''.join(out)


def rewrite_modern_std_helpers(code):
    code = code.replace('#include <concepts>', '// cpp-tutor: <concepts> not needed after local visualizer rewrites')
    code = code.replace('#include <bit>', '// cpp-tutor: <bit> helpers rewritten for local visualizer')

    code = re.sub(
        r'std::cmp_(?P<op>equal|not_equal|less|less_equal|greater|greater_equal)\s*\(\s*(?P<a>[^,\n]+?)\s*,\s*(?P<b>[^;\n]+?)\s*\)',
        lambda m: '__cpp_tutor_cmp_%s(%s, %s)' % (m.group('op'), m.group('a'), m.group('b')),
        code
    )

    code = re.sub(
        r'std::to_underlying\s*\(\s*(?P<value>[^;\n]+?)\s*\)',
        lambda m: 'static_cast<int>(%s)' % m.group('value'),
        code
    )

    code = re.sub(
        r'std::midpoint\s*\(\s*(?P<a>[^,\n]+?)\s*,\s*(?P<b>[^;\n]+?)\s*\)',
        lambda m: '((%s) + ((%s) - (%s)) / 2)' % (m.group('a'), m.group('b'), m.group('a')),
        code
    )

    code = re.sub(
        r'std::lerp\s*\(\s*(?P<a>[^,\n]+?)\s*,\s*(?P<b>[^,\n]+?)\s*,\s*(?P<t>[^;\n]+?)\s*\)',
        lambda m: '((%s) + ((%s) - (%s)) * (%s))' % (
            m.group('a'), m.group('b'), m.group('a'), m.group('t')
        ),
        code
    )

    code = re.sub(
        r'std::clamp\s*\(\s*(?P<v>[^,\n]+?)\s*,\s*(?P<lo>[^,\n]+?)\s*,\s*(?P<hi>[^;\n]+?)\s*\)',
        lambda m: '((%s) < (%s) ? (%s) : ((%s) > (%s) ? (%s) : (%s)))' % (
            m.group('v'), m.group('lo'), m.group('lo'),
            m.group('v'), m.group('hi'), m.group('hi'), m.group('v')
        ),
        code
    )

    code = re.sub(
        r'std::gcd\s*\(\s*(?P<a>[^,\n]+?)\s*,\s*(?P<b>[^;\n]+?)\s*\)',
