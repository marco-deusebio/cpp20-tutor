def math_helper_source():
    return '''
template <class T>
T __cpp_tutor_abs_value(T value) {
    return value < 0 ? -value : value;
}

template <class T, class U>
long long __cpp_tutor_gcd(T a, U b) {
    long long x = __cpp_tutor_abs_value(static_cast<long long>(a));
    long long y = __cpp_tutor_abs_value(static_cast<long long>(b));
    while (y != 0) {
        long long r = x % y;
        x = y;
        y = r;
    }
    return x;
}

template <class T, class U>
long long __cpp_tutor_lcm(T a, U b) {
    long long x = static_cast<long long>(a);
    long long y = static_cast<long long>(b);
    if (x == 0 || y == 0) {
        return 0;
    }
    return __cpp_tutor_abs_value((x / __cpp_tutor_gcd(x, y)) * y);
}

template <class T>
int __cpp_tutor_bit_width(T value) {
    unsigned long long x = static_cast<unsigned long long>(value);
    int width = 0;
    while (x != 0) {
        ++width;
        x >>= 1;
    }
    return width;
}

