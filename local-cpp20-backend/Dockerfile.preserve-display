def rewrite_structured_binding_for_loops(code):
    lines = code.splitlines(True)
    out = []
    pending = None
    counter = 0

    pattern = re.compile(
        r'^(?P<indent>\s*)for\s*\(\s*'
        r'(?P<decl>(?:const\s+)?auto(?:\s*(?:&|&&))?)\s*'
        r'\[\s*(?P<names>[A-Za-z_]\w*(?:\s*,\s*[A-Za-z_]\w*)+)\s*\]\s*'
        r':\s*(?P<expr>.*?)\s*\)\s*(?P<brace>\{?)\s*(?P<tail>//.*)?(?P<nl>\r?\n?)$'
    )

    for line in lines:
        match = pattern.match(line)

        if match:
            counter += 1
            indent = match.group('indent')
            names = split_names(match.group('names'))
            expr = match.group('expr')
            brace = match.group('brace')
            tail = match.group('tail') or ''
            nl = match.group('nl') or '\n'
            temp = '__cpp_tutor_sb_%d' % counter

            getters = ' '.join(
                ['auto %s = std::get<%d>(%s);' % (name, i, temp) for i, name in enumerate(names)]
            )

            if brace:
                out.append('%sfor (auto&& %s : %s) { %s%s%s' %
                           (indent, temp, expr, getters, (' ' + tail) if tail else '', nl))
            else:
                out.append('%sfor (auto&& %s : %s)%s%s' %
                           (indent, temp, expr, (' ' + tail) if tail else '', nl))
                pending = (indent, getters)

            continue

        if pending and line.strip().startswith('{'):
            indent, getters = pending
            nl = '\n' if line.endswith('\n') else ''
            out.append('%s{ %s%s' % (indent, getters, nl))
            pending = None
            continue

        out.append(line)

    return ''.join(out)


def rewrite_standalone_structured_bindings_safely(code):
    lines = code.splitlines(True)
    out = []

    pattern = re.compile(
        r'^(?P<indent>\s*)'
        r'(?P<decl>(?:const\s+)?auto(?:\s*(?:&|&&))?)\s*'
        r'\[\s*(?P<names>[A-Za-z_]\w*(?:\s*,\s*[A-Za-z_]\w*)+)\s*\]\s*'
        r'=\s*(?P<expr>.*?);\s*(?P<tail>//.*)?(?P<nl>\r?\n?)$'
    )

    for line in lines:
        match = pattern.match(line)

        if not match:
            out.append(line)
            continue

        indent = match.group('indent')
        names = split_names(match.group('names'))
        expr = match.group('expr')
        tail = match.group('tail') or ''
        nl = match.group('nl') or '\n'

        pieces = [
            'auto %s = std::get<%d>(%s);' % (name, i, expr)
            for i, name in enumerate(names)
        ]

        out.append('%s%s%s%s' % (
            indent,
            ' '.join(pieces),
            (' ' + tail) if tail else '',
            nl
        ))

    return ''.join(out)


def add_needed_includes(original_code, rewritten_code):
    prefix = ''

    if 'std::cmp_' in original_code:
        prefix += cmp_helper_source()

    if any(token in original_code for token in (
        'std::gcd(', 'std::lcm(', 'std::bit_width(', 'std::bit_floor(', 'std::bit_ceil('
    )):
        prefix += math_helper_source()

    if ('auto [' in original_code or 'const auto [' in original_code or 'auto& [' in original_code or 'auto&& [' in original_code):
        if '#include <tuple>' not in rewritten_code:
            prefix += '#include <tuple>\n'

    if ('std::ranges::sort' in original_code or 'std::ranges::reverse' in original_code):
        if '#include <algorithm>' not in rewritten_code:
            prefix += '#include <algorithm>\n'

    if any(token in original_code for token in (
        '.starts_with(', '.ends_with(', '.contains(', 'std::cmp_', 'std::to_underlying(',
        'std::midpoint(', 'std::lerp(', 'std::clamp(', 'std::erase(', 'std::erase_if(',
        'std::ranges::'
    )):
        if '#include <algorithm>' not in rewritten_code:
            prefix += '#include <algorithm>\n'
        if '#include <string>' not in rewritten_code:
            prefix += '#include <string>\n'

    if any(token in original_code for token in (
        'std::ranges::copy', 'std::ranges::copy_if', 'std::ranges::transform',
        'back_inserter(', 'std::back_inserter('
    )):
        if '#include <iterator>' not in rewritten_code:
            prefix += '#include <iterator>\n'

    if prefix:
        prefix += '#line 1\n'

    return prefix + rewritten_code


def is_synthetic_frame(frame):
    return '__cpp_tutor_' in frame.get('func_name', '')


def is_internal_frame(frame):
    func_name = frame.get('func_name', '')
    return (
        func_name.startswith('std::') or
        func_name.startswith('__gnu_cxx::') or
        func_name.startswith('bool __gnu_cxx::') or
        func_name.startswith('__static_initialization_and_destruction_0') or
        func_name.startswith('_GLOBAL__sub_I_') or
        func_name == '__libc_csu_init'
    )


def filter_synthetic_trace(data):
    original_lines = len(data.get('code', '').split('\n'))
    filtered_trace = []

    for entry in data.get('trace', []):
        if '__cpp_tutor_' in entry.get('func_name', ''):
            continue
        if is_internal_frame(entry):
            continue
        line = entry.get('line')
        if isinstance(line, int) and line > original_lines:
            continue

        stack = entry.get('stack_to_render')
        if stack:
            visible_stack = []
            for frame in stack:
                if is_synthetic_frame(frame) or is_internal_frame(frame):
                    continue

                encoded_locals = frame.get('encoded_locals')
                if encoded_locals:
                    for name in list(encoded_locals.keys()):
                        if name.startswith('__cpp_tutor_'):
                            del encoded_locals[name]

                ordered_varnames = frame.get('ordered_varnames')
                if ordered_varnames:
                    frame['ordered_varnames'] = [
                        name for name in ordered_varnames
                        if not name.startswith('__cpp_tutor_')
                    ]

                visible_stack.append(frame)

            entry['stack_to_render'] = visible_stack

        filtered_trace.append(entry)

    data['trace'] = filtered_trace
    return data


def rewrite_code(code):
    rewritten = code

    rewritten = rewrite_numbers(rewritten)
    rewritten = rewrite_ssize(rewritten)
    rewritten = rewrite_modern_std_helpers(rewritten)

    rewritten, known_strings = rewrite_simple_string_literals(rewritten)
    rewritten = rewrite_string_predicates(rewritten, known_strings)

    rewritten = rewrite_iota_view_for_loops(rewritten)
    rewritten = rewrite_reverse_view_for_loops(rewritten)
    rewritten = rewrite_filter_transform_view_for_loops(rewritten)
    rewritten = rewrite_structured_binding_for_loops(rewritten)
    rewritten = rewrite_standalone_structured_bindings_safely(rewritten)
    rewritten = rewrite_safe_ranges(rewritten)
    rewritten = add_needed_includes(code, rewritten)

    return rewritten


