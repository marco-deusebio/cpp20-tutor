def split_names(names):
    return [name.strip() for name in names.split(',') if name.strip()]


def char_literal(ch):
    if ch == "'":
        return "\\'"
    if ch == "\\":
        return "\\\\"
    if ch == "\n":
        return "\\n"
    if ch == "\t":
        return "\\t"
    return ch


def rewrite_simple_string_literals(code):
    # Keep real std::string objects so the backend can visualize mutations.
    return code, {}


def rewrite_string_predicates(code, known_strings):
    predicate_pattern = re.compile(
        r'(?P<obj>\b[A-Za-z_]\w*)\.(?P<method>starts_with|ends_with|contains)\s*\((?P<arg>"[^"]*")\)'
    )

    def repl(match):
        obj = match.group('obj')
        method = match.group('method')
        arg = match.group('arg')
        literal = arg[1:-1]

        if obj in known_strings:
            text_value = known_strings[obj]

            if method == 'starts_with':
                return 'true' if text_value.startswith(literal) else 'false'
            if method == 'ends_with':
                return 'true' if text_value.endswith(literal) else 'false'
            return 'true' if literal in text_value else 'false'

        if method == 'starts_with':
            return '(std::string(%s).rfind(%s, 0) == 0)' % (obj, arg)
        if method == 'ends_with':
            return '(std::string(%s).size() >= std::string(%s).size() && std::string(%s).compare(std::string(%s).size() - std::string(%s).size(), std::string(%s).size(), %s) == 0)' % (
                obj, arg, obj, obj, arg, arg, arg
            )

        return '(std::string(%s).find(%s) != std::string::npos)' % (obj, arg)

    code = predicate_pattern.sub(repl, code)

    return code


def rewrite_numbers(code):
    code = code.replace('#include <numbers>', '// cpp-tutor: <numbers> constants rewritten for local visualizer')

    replacements = {
        'std::numbers::pi_v<double>': '3.14159265358979323846264338327950288',
        'std::numbers::pi': '3.14159265358979323846264338327950288',
        'std::numbers::e_v<double>': '2.7182818284590452353602874713527',
        'std::numbers::e': '2.7182818284590452353602874713527',
        'std::numbers::sqrt2_v<double>': '1.4142135623730950488016887242097',
        'std::numbers::sqrt2': '1.4142135623730950488016887242097',
    }

    for old, new in replacements.items():
        code = code.replace(old, new)

    return code


def rewrite_ssize(code):
    return re.sub(
        r'std::ssize\s*\(\s*(?P<c>[A-Za-z_]\w*(?:\.[A-Za-z_]\w*)*)\s*\)',
        lambda m: 'static_cast<long long>(%s.size())' % m.group('c'),
        code
    )


def rewrite_safe_ranges(code):
    code = code.replace('#include <ranges>', '// cpp-tutor: <ranges> rewritten for local visualizer')

    one_range_algorithms = (
        'sort', 'stable_sort', 'reverse', 'shuffle', 'unique',
        'is_sorted', 'is_heap', 'make_heap', 'pop_heap', 'push_heap', 'sort_heap'
    )

    for name in one_range_algorithms:
        code = re.sub(
            r'std::ranges::%s\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*\)' % name,
            lambda m, name=name: 'std::%s(%s.begin(), %s.end())' % (
                name, m.group('c'), m.group('c')
            ),
            code
        )

    for name in (
        'find', 'count', 'binary_search', 'lower_bound', 'upper_bound',
        'min_element', 'max_element', 'is_sorted_until', 'adjacent_find'
    ):
        code = re.sub(
            r'std::ranges::%s\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<value>[^;\n]+?)\s*\)' % name,
            lambda m, name=name: 'std::%s(%s.begin(), %s.end(), %s)' % (
                name, m.group('c'), m.group('c'), m.group('value')
            ),
            code
        )

    for name in ('min_element', 'max_element', 'is_sorted_until', 'adjacent_find'):
        code = re.sub(
            r'std::ranges::%s\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*\)' % name,
            lambda m, name=name: 'std::%s(%s.begin(), %s.end())' % (
                name, m.group('c'), m.group('c')
            ),
            code
        )

    for name in ('all_of', 'any_of', 'none_of', 'find_if', 'find_if_not', 'count_if', 'for_each'):
        code = re.sub(
            r'std::ranges::%s\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<pred>(?:\[[^\]]*\]\s*\([^)]*\)\s*\{[^}]*\}|[^)\n]+))\s*\)' % name,
            lambda m, name=name: 'std::%s(%s.begin(), %s.end(), %s)' % (
                name, m.group('c'), m.group('c'), m.group('pred')
            ),
            code
        )

    for name in ('fill', 'replace'):
        code = re.sub(
            r'std::ranges::%s\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<args>[^;\n]+?)\s*\)' % name,
            lambda m, name=name: 'std::%s(%s.begin(), %s.end(), %s)' % (
                name, m.group('c'), m.group('c'), m.group('args')
            ),
            code
        )

    code = re.sub(
        r'std::ranges::copy\s*\(\s*(?P<src>[A-Za-z_]\w*)\s*,\s*(?P<dest>[^;\n]+?)\s*\)',
        lambda m: 'std::copy(%s.begin(), %s.end(), %s)' % (
            m.group('src'), m.group('src'), m.group('dest')
        ),
        code
    )

    code = re.sub(
        r'std::ranges::copy_if\s*\(\s*(?P<src>[A-Za-z_]\w*)\s*,\s*(?P<dest>[^,\n]+?)\s*,\s*(?P<pred>(?:\[[^\]]*\]\s*\([^)]*\)\s*\{[^}]*\}|[^)\n]+))\s*\)',
        lambda m: 'std::copy_if(%s.begin(), %s.end(), %s, %s)' % (
            m.group('src'), m.group('src'), m.group('dest'), m.group('pred')
        ),
        code
    )

    code = re.sub(
        r'std::ranges::transform\s*\(\s*(?P<src>[A-Za-z_]\w*)\s*,\s*(?P<dest>[^,\n]+?)\s*,\s*(?P<func>(?:\[[^\]]*\]\s*\([^)]*\)\s*\{[^}]*\}|[^)\n]+))\s*\)',
        lambda m: 'std::transform(%s.begin(), %s.end(), %s, %s)' % (
            m.group('src'), m.group('src'), m.group('dest'), m.group('func')
        ),
        code
    )

    code = re.sub(
        r'std::ranges::equal\s*\(\s*(?P<a>[A-Za-z_]\w*)\s*,\s*(?P<b>[A-Za-z_]\w*)\s*\)',
        lambda m: 'std::equal(%s.begin(), %s.end(), %s.begin(), %s.end())' % (
            m.group('a'), m.group('a'), m.group('b'), m.group('b')
        ),
        code
    )

    code = re.sub(
        r'std::ranges::includes\s*\(\s*(?P<a>[A-Za-z_]\w*)\s*,\s*(?P<b>[A-Za-z_]\w*)\s*\)',
        lambda m: 'std::includes(%s.begin(), %s.end(), %s.begin(), %s.end())' % (
            m.group('a'), m.group('a'), m.group('b'), m.group('b')
        ),
        code
    )

    for name in ('size', 'empty', 'data'):
        code = re.sub(
            r'std::ranges::%s\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*\)' % name,
            lambda m, name=name: '%s.%s()' % (m.group('c'), name),
            code
        )

    code = re.sub(
        r'std::ranges::distance\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*\)',
