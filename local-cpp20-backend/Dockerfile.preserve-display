    code = re.sub(
        r'std::ranges::min\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*\)',
        lambda m: '(*std::min_element(%s.begin(), %s.end()))' % (m.group('c'), m.group('c')),
        code
