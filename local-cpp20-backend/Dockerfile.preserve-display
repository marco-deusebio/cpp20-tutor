    )

    code = re.sub(
        r'std::ranges::contains\s*\(\s*(?P<c>[A-Za-z_]\w*)\s*,\s*(?P<value>[^;\n]+?)\s*\)',
        lambda m: '(std::find(%s.begin(), %s.end(), %s) != %s.end())' % (
            m.group('c'), m.group('c'), m.group('value'), m.group('c')
