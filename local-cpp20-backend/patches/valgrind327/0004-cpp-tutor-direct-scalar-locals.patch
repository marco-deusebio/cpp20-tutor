+static void pg_emit_json_string(VgFile* trace_fp, const HChar* str)
+{
+   const HChar* p;
+   VG_(fprintf)(trace_fp, "\"");
+   for (p = str; p && *p; p++) {
+      switch (*p) {
+         case '"':  VG_(fprintf)(trace_fp, "\\\""); break;
+         case '\\': VG_(fprintf)(trace_fp, "\\\\"); break;
+         case '\n': VG_(fprintf)(trace_fp, "\\n"); break;
+         case '\r': VG_(fprintf)(trace_fp, "\\r"); break;
+         case '\t': VG_(fprintf)(trace_fp, "\\t"); break;
+         default:   VG_(fprintf)(trace_fp, "%c", *p); break;
+      }
+   }
+   VG_(fprintf)(trace_fp, "\"");
+}
+
+static TyEnt* pg_resolve_display_type(const XArray* tyents, UWord cuOff)
+{
+   TyEnt* ent = ML_(TyEnts__index_by_cuOff)(tyents, NULL, cuOff);
+   while (ent && (ent->tag == Te_TyQual || ent->tag == Te_TyTyDef)) {
+      if (ent->tag == Te_TyQual)
+         ent = ML_(TyEnts__index_by_cuOff)(tyents, NULL, ent->Te.TyQual.typeR);
+      else
+         ent = ML_(TyEnts__index_by_cuOff)(tyents, NULL, ent->Te.TyTyDef.typeR);
+   }
+   return ent;
+}
+
+static void pg_emit_unsupported_varinfo(VgFile* trace_fp, Addr data_addr,
+                                        const HChar* type_name)
+{
+   VG_(fprintf)(trace_fp,
+                "{\"addr\":\"%p\", \"kind\":\"base\", \"type\":\"%s\", \"size\":0, \"val\":\"<UNSUPPORTED>\"}",
+                (void*)data_addr,
+                type_name ? type_name : "<unsupported>");
+}
+
+static void pg_emit_minimal_varinfo(const XArray* tyents, UWord typeR,
+                                    Addr data_addr,
+                                    Int (*is_mem_defined_func)(Addr, SizeT, Addr*, UInt*),
+                                    VgFile* trace_fp)
+{
+   TyEnt* ent = pg_resolve_display_type(tyents, typeR);
+   Addr bad_addr;
+   UInt otag = 0;
+   Int res;
+
+   if (!ent) {
+      pg_emit_unsupported_varinfo(trace_fp, data_addr, "<unknown>");
+      return;
+   }
+
+   if (ent->tag == Te_TyEnum) {
+      VG_(fprintf)(trace_fp,
+                   "{\"addr\":\"%p\", \"kind\":\"base\", \"type\":\"%s\", \"size\":%u, \"val\":",
+                   (void*)data_addr,
+                   ent->Te.TyEnum.name ? ent->Te.TyEnum.name : "anonymous enum",
+                   ent->Te.TyEnum.szB);
+      res = is_mem_defined_func(data_addr, ent->Te.TyEnum.szB, &bad_addr, &otag);
+      if (res == 6) {
+         VG_(fprintf)(trace_fp, "\"<UNALLOCATED>\"}");
+      } else if (res == 7) {
+         VG_(fprintf)(trace_fp, "\"<UNINITIALIZED>\"}");
+      } else if (ent->Te.TyEnum.szB <= sizeof(int)) {
+         VG_(fprintf)(trace_fp, "%d}", *((int*)data_addr));
+      } else {
+         VG_(fprintf)(trace_fp, "%lld}", *((long long int*)data_addr));
+      }
+      return;
+   }
+
+   if (ent->tag != Te_TyBase) {
+      pg_emit_unsupported_varinfo(trace_fp, data_addr, "<non-scalar>");
+      return;
+   }
+
+   VG_(fprintf)(trace_fp,
+                "{\"addr\":\"%p\", \"kind\":\"base\", \"type\":\"%s\", \"size\":%u, \"val\":",
+                (void*)data_addr,
+                ent->Te.TyBase.name ? ent->Te.TyBase.name : "<anonymous>",
+                ent->Te.TyBase.szB);
+
+   res = is_mem_defined_func(data_addr, ent->Te.TyBase.szB, &bad_addr, &otag);
+   if (res == 6) {
+      VG_(fprintf)(trace_fp, "\"<UNALLOCATED>\"}");
+      return;
+   }
+   if (res == 7) {
+      VG_(fprintf)(trace_fp, "\"<UNINITIALIZED>\"}");
+      return;
+   }
+
+   switch (ent->Te.TyBase.enc) {
+      case 'S':
+         if (ent->Te.TyBase.szB == sizeof(char)) {
+            HChar str[3];
+            HChar val = *((char*)data_addr);
+            if (val == '\0') {
+               str[0] = '\\'; str[1] = '0'; str[2] = 0;
+            } else {
+               str[0] = val; str[1] = 0;
+            }
+            pg_emit_json_string(trace_fp, str);
+         } else if (ent->Te.TyBase.szB == sizeof(short)) {
+            VG_(fprintf)(trace_fp, "%d", *((short*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(int)) {
+            VG_(fprintf)(trace_fp, "%d", *((int*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(long int)) {
+            VG_(fprintf)(trace_fp, "%ld", *((long int*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(long long int)) {
+            VG_(fprintf)(trace_fp, "%lld", *((long long int*)data_addr));
+         } else {
+            VG_(fprintf)(trace_fp, "\"<UNSUPPORTED>\"");
+         }
+         break;
+      case 'U':
+         if (ent->Te.TyBase.szB == sizeof(unsigned char)) {
+            VG_(fprintf)(trace_fp, "%u", *((unsigned char*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(unsigned short)) {
+            VG_(fprintf)(trace_fp, "%u", *((unsigned short*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(unsigned int)) {
+            VG_(fprintf)(trace_fp, "%u", *((unsigned int*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(unsigned long int)) {
+            VG_(fprintf)(trace_fp, "%lu", *((unsigned long int*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(unsigned long long int)) {
+            VG_(fprintf)(trace_fp, "%llu", *((unsigned long long int*)data_addr));
+         } else {
+            VG_(fprintf)(trace_fp, "\"<UNSUPPORTED>\"");
+         }
+         break;
+      case 'F':
+         if (ent->Te.TyBase.szB == sizeof(float)) {
+            VG_(fprintf)(trace_fp, "%f", *((float*)data_addr));
+         } else if (ent->Te.TyBase.szB == sizeof(double)) {
+            VG_(fprintf)(trace_fp, "%f", *((double*)data_addr));
+         } else {
+            VG_(fprintf)(trace_fp, "\"<UNSUPPORTED>\"");
+         }
+         break;
+      default:
+         VG_(fprintf)(trace_fp, "\"<UNSUPPORTED>\"");
+         break;
+   }
+
+   VG_(fprintf)(trace_fp, "}");
+}
+
+static Word pg_collect_local_vars(PgLocalVar* locals, Word max_locals,
+                                  DiEpoch ep, Addr ip, Addr sp, Addr fp)
+{
+   Word i;
+   Word n_locals = 0;
+   DebugInfo* di;
+   RegSummary regs;
+
+   for (di = debugInfo_list; di; di = di->next) {
+      if (!is_DI_valid_for_epoch(di, ep))
+         continue;
+      if (!di->text_present || di->text_size == 0)
+         continue;
+      if (di->text_avma <= ip && ip < di->text_avma + di->text_size)
+         break;
+   }
+
+   if (!di || !di->varinfo)
+      return 0;
+
+   regs.ip = ip;
+   regs.sp = sp;
+   regs.fp = fp;
+
+   for (i = VG_(sizeXA)(di->varinfo) - 1; i >= 1; i--) {
+      XArray* vars;
+      Word j;
+      DiAddrRange* arange;
+      OSet* this_scope = *(OSet**)VG_(indexXA)(di->varinfo, i);
+      if (!this_scope)
+         continue;
+
+      arange = VG_(OSetGen_LookupWithCmp)(
+         this_scope, &ip, ML_(cmp_for_DiAddrRange_range)
+      );
+      if (!arange || !arange->vars)
+         continue;
+
+      vars = arange->vars;
+      for (j = 0; j < VG_(sizeXA)(vars) && n_locals < max_locals; j++) {
+         DiVariable* var = (DiVariable*)VG_(indexXA)(vars, j);
+         GXResult res;
+         MaybeULong mul;
+         if (!var->name || !var->gexpr)
+            continue;
+         mul = ML_(sizeOfType)(di->admin_tyents, var->typeR);
+         if (!mul.b || mul.ul == 0)
+            continue;
+         res = ML_(evaluate_GX)(var->gexpr, var->fbGX, &regs, di);
+         if (res.kind != GXR_Addr)
+            continue;
+         locals[n_locals].name = var->name;
+         locals[n_locals].addr = res.word;
+         locals[n_locals].typeR = var->typeR;
+         locals[n_locals].tyents = di->admin_tyents;
+         n_locals++;
+      }
+   }
+
+   return n_locals;
 }
 
+Bool VG_(pg_emit_local_vars_for_frame)(
+   DiEpoch ep,
+   Addr ip, Addr sp, Addr fp,
+   Int (*is_mem_defined_func)(Addr, SizeT, Addr*, UInt*),
+   VgFile* trace_fp
+)
+{
+   PgLocalVar locals[PG_MAX_LOCAL_VARS];
+   Word i;
+   Word n_locals = pg_collect_local_vars(locals, PG_MAX_LOCAL_VARS,
+                                         ep, ip, sp, fp);
+
+   if (n_locals == 0)
+      n_locals = pg_collect_local_vars(locals, PG_MAX_LOCAL_VARS,
+                                       ep, ip + 1, sp, fp);
+
+   VG_(fprintf)(trace_fp, "\"locals\": {\n");
+   for (i = 0; i < n_locals; i++) {
+      if (i > 0)
+         VG_(fprintf)(trace_fp, ",\n");
+      VG_(fprintf)(trace_fp, "  ");
+      pg_emit_json_string(trace_fp, locals[i].name);
+      VG_(fprintf)(trace_fp, ": ");
+      pg_emit_minimal_varinfo(locals[i].tyents, locals[i].typeR,
+                              locals[i].addr, is_mem_defined_func, trace_fp);
+   }
+   VG_(fprintf)(trace_fp, "},\n\"ordered_varnames\": [");
+   for (i = 0; i < n_locals; i++) {
+      if (i > 0)
+         VG_(fprintf)(trace_fp, ",");
+      pg_emit_json_string(trace_fp, locals[i].name);
+   }
+   VG_(fprintf)(trace_fp, "]");
+
+   return n_locals > 0;
+}
