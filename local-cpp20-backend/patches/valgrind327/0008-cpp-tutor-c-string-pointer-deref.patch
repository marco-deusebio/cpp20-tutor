+static TyEnt* pg_resolve_c_string_char_type(const XArray* tyents, UWord typeR)
+{
+   TyEnt* ent = pg_resolve_display_type(tyents, typeR);
+   if (!ent || ent->tag != Te_TyBase)
+      return NULL;
+   if (ent->Te.TyBase.enc != 'S' || ent->Te.TyBase.szB != sizeof(char))
+      return NULL;
+   return ent;
+}
+
+static void pg_emit_json_char_value(VgFile* trace_fp, HChar ch)
+{
+   switch (ch) {
+      case '\0': VG_(fprintf)(trace_fp, "\"\\\\0\""); break;
+      case '"':  VG_(fprintf)(trace_fp, "\"\\\"\""); break;
+      case '\\': VG_(fprintf)(trace_fp, "\"\\\\\""); break;
+      case '\n': VG_(fprintf)(trace_fp, "\"\\\\n\""); break;
+      case '\r': VG_(fprintf)(trace_fp, "\"\\\\r\""); break;
+      case '\t': VG_(fprintf)(trace_fp, "\"\\\\t\""); break;
+      default:
+         if ((UChar)ch < 0x20)
+            VG_(fprintf)(trace_fp, "\"\\\\u%04x\"", (UInt)(UChar)ch);
+         else
+            VG_(fprintf)(trace_fp, "\"%c\"", ch);
+         break;
+   }
+}
+
+static Bool pg_c_string_len_if_safe(Addr ptr_val,
+                                    Int (*is_mem_defined_func)(Addr, SizeT, Addr*, UInt*),
+                                    Word* n_chars)
+{
+   Word i;
+   Addr bad_addr;
+   UInt otag = 0;
+
+   *n_chars = 0;
+   if (ptr_val == 0)
+      return False;
+
+   for (i = 0; i < PG_MAX_C_STRING_CHARS; i++) {
+      Int res = is_mem_defined_func(ptr_val + i, sizeof(char), &bad_addr, &otag);
+      HChar ch;
+
+      if (res != 5)
+         return False;
+
+      ch = *((HChar*)(ptr_val + i));
+      if (ch == '\0') {
+         *n_chars = i + 1;
+         return True;
+      }
+   }
+
+   return False;
 }
 
+static void pg_emit_c_string_deref_val(Addr ptr_val,
+                                       TyEnt* char_ent,
+                                       Int (*is_mem_defined_func)(Addr, SizeT, Addr*, UInt*),
+                                       VgFile* trace_fp)
+{
+   Word i;
+   Word n_chars;
+   const HChar* type_name;
+
+   if (!pg_c_string_len_if_safe(ptr_val, is_mem_defined_func, &n_chars))
+      return;
+
+   type_name = char_ent->Te.TyBase.name ? char_ent->Te.TyBase.name : "char";
+   VG_(fprintf)(trace_fp,
+                ", \"deref_val\":{\"addr\":\"%p\", \"kind\":\"heap_block\", \"val\":[",
+                (void*)ptr_val);
+
+   for (i = 0; i < n_chars; i++) {
+      HChar ch = *((HChar*)(ptr_val + i));
+      if (i > 0)
+         VG_(fprintf)(trace_fp, ", ");
+      VG_(fprintf)(trace_fp,
+                   "{\"addr\":\"%p\", \"kind\":\"base\", \"type\":\"%s\", \"size\":1, \"val\":",
+                   (void*)(ptr_val + i),
+                   type_name);
+      pg_emit_json_char_value(trace_fp, ch);
+      VG_(fprintf)(trace_fp, "}");
+   }
+
+   VG_(fprintf)(trace_fp, "]}");
+}
