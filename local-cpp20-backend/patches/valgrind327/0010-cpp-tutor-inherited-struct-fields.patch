+static void pg_emit_struct_fields(const XArray* tyents,
+                                  TyEnt* ent,
+                                  Addr data_addr,
+                                  DiEpoch ep,
+                                  Bool* first_field,
+                                  UInt* field_count,
+                                  Int (*is_mem_defined_func)(Addr, SizeT, Addr*, UInt*),
+                                  VgFile* trace_fp)
+{
+   Word i;
+   XArray* fieldRs;
+
+   if (!ent || ent->tag != Te_TyStOrUn || !ent->Te.TyStOrUn.complete ||
+       !ent->Te.TyStOrUn.isStruct || !ent->Te.TyStOrUn.fieldRs) {
+      return;
+   }
 
+   fieldRs = ent->Te.TyStOrUn.fieldRs;
+   for (i = 0; i < VG_(sizeXA)(fieldRs); i++) {
+      UWord fieldR = *(UWord*)VG_(indexXA)(fieldRs, i);
+      TyEnt* field = ML_(TyEnts__index_by_cuOff)(tyents, NULL, fieldR);
+      TyEnt* field_ent;
+      Addr field_addr;
+
+      if (*field_count >= PG_MAX_STRUCT_FIELDS)
+         return;
+
+      if (!field || field->tag != Te_Field || !field->Te.Field.isStruct ||
+          field->Te.Field.nLoc != -1) {
+         continue;
+      }
+
+      field_addr = data_addr + field->Te.Field.pos.offset;
+      field_ent = pg_resolve_display_type(tyents, field->Te.Field.typeR);
+
+      if (!field->Te.Field.name) {
+         if (field_ent && field_ent->tag == Te_TyStOrUn) {
+            pg_emit_struct_fields(tyents, field_ent, field_addr, ep,
+                                  first_field, field_count,
+                                  is_mem_defined_func, trace_fp);
+         }
+         continue;
+      }
+
+      if (!*first_field)
+         VG_(fprintf)(trace_fp, ",\n  ");
+      *first_field = False;
+      (*field_count)++;
+
+      pg_emit_json_string(trace_fp, field->Te.Field.name);
+      VG_(fprintf)(trace_fp, ":");
+      pg_emit_minimal_varinfo(tyents, field->Te.Field.typeR, field_addr,
+                              ep, False, is_mem_defined_func, trace_fp);
+   }
+
+   if (*field_count < PG_MAX_STRUCT_FIELDS && ent->Te.TyStOrUn.typeR != 0) {
+      TyEnt* base = ML_(TyEnts__index_by_cuOff)(tyents, NULL,
+                                                ent->Te.TyStOrUn.typeR);
+      if (base && base->tag != Te_UNKNOWN && ML_(TyEnt__is_type)(base)) {
+         pg_emit_struct_fields(tyents, base, data_addr, ep,
+                               first_field, field_count,
+                               is_mem_defined_func, trace_fp);
+      }
+   }
+}
