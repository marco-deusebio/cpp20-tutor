+static void pg_emit_heap_deref_val(const XArray* tyents, UWord typeR,
+                                   Addr ptr_val, DiEpoch ep,
+                                   Int (*is_mem_defined_func)(Addr, SizeT, Addr*, UInt*),
+                                   VgFile* trace_fp)
+{
+   AddrInfo ai;
+   MaybeULong element_size;
+   Addr block_base_addr;
+   ULong n_elements;
+   ULong i;
+   Addr cur_addr;
+   Addr bad_addr;
+   UInt otag = 0;
+   Int res;
+
+   if (ptr_val == 0)
+      return;
+
+   ai.tag = Addr_Undescribed;
+   VG_(describe_addr)(ep, ptr_val, &ai);
+   if (ai.tag != Addr_Block) {
+      VG_(clear_addrinfo)(&ai);
+      return;
+   }
+
+   element_size = ML_(sizeOfType)(tyents, typeR);
+   if (!element_size.b || element_size.ul == 0 || ai.Addr.Block.block_szB == 0) {
+      VG_(clear_addrinfo)(&ai);
+      return;
+   }
+
+   block_base_addr = ptr_val - ai.Addr.Block.rwoffset;
+   n_elements = ai.Addr.Block.block_szB / element_size.ul;
+   if (n_elements == 0) {
+      VG_(clear_addrinfo)(&ai);
+      return;
+   }
+   if (n_elements > PG_MAX_HEAP_ELEMENTS)
+      n_elements = PG_MAX_HEAP_ELEMENTS;
+   for (i = 0; i < n_elements; i++) {
+      cur_addr = block_base_addr + (i * element_size.ul);
+      res = is_mem_defined_func(cur_addr, element_size.ul, &bad_addr, &otag);
+      if (res == 6)
+         break;
+   }
+   n_elements = i;
+   if (n_elements == 0) {
+      VG_(clear_addrinfo)(&ai);
+      return;
+   }
+
+   VG_(fprintf)(trace_fp,
+                ", \"deref_val\":{\"addr\":\"%p\", \"kind\":\"heap_block\", \"val\":[\n  ",
+                (void*)block_base_addr);
+   cur_addr = block_base_addr;
+   for (i = 0; i < n_elements; i++) {
+      if (i > 0)
+         VG_(fprintf)(trace_fp, ",\n  ");
+      pg_emit_minimal_varinfo(tyents, typeR, cur_addr, ep, False,
+                              is_mem_defined_func, trace_fp);
+      cur_addr += element_size.ul;
+   }
+   VG_(fprintf)(trace_fp, "]}");
+
+   VG_(clear_addrinfo)(&ai);
+}
