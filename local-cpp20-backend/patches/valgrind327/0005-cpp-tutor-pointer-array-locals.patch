+
+static Bool pg_array_element_count(const XArray* tyents,
+                                   TyEnt* ent,
+                                   Long* dimensions,
+                                   Word max_dimensions,
+                                   Word* n_dimensions,
+                                   ULong* total_elements)
+{
+   Word i;
+   ULong total = 1;
+   XArray* xa;
+
+   *n_dimensions = 0;
+   *total_elements = 0;
+   if (!ent->Te.TyArray.boundRs)
+      return False;
+
+   xa = ent->Te.TyArray.boundRs;
+   if (VG_(sizeXA)(xa) > max_dimensions)
+      return False;
+
+   for (i = 0; i < VG_(sizeXA)(xa); i++) {
+      UWord bound_cuOff = *(UWord*)VG_(indexXA)(xa, i);
+      TyEnt* bound_ent = ML_(TyEnts__index_by_cuOff)(tyents, NULL, bound_cuOff);
+      Long dimension;
+      if (!bound_ent || bound_ent->tag != Te_Bound)
+         return False;
+      if (!bound_ent->Te.Bound.knownL || !bound_ent->Te.Bound.knownU)
+         return False;
+      if (bound_ent->Te.Bound.boundL != 0)
+         return False;
+
+      dimension = bound_ent->Te.Bound.boundU + 1;
+      if (dimension <= 0)
+         return False;
+      if (total > PG_MAX_ARRAY_ELEMENTS / (ULong)dimension)
+         return False;
+
+      dimensions[i] = dimension;
+      total *= (ULong)dimension;
+   }
+
+   *n_dimensions = VG_(sizeXA)(xa);
+   *total_elements = total;
+   return True;
 }
 
