+def get_std_error_value_summary(obj, heap):
+    if obj.get('kind') != 'struct':
+        return None
+
+    type_name = display_cpp_type(obj.get('type') or '')
+    if type_name not in ('error_code', 'std::error_code',
+                         'error_condition', 'std::error_condition'):
+        return None
+
+    value = get_direct_struct_member(obj, '_M_value')
+    category = get_direct_struct_member(obj, '_M_cat')
+    if value is None or not category or category.get('kind') != 'pointer':
+        return None
+
+    if type_name.endswith('error_code'):
+        display_type = 'std::error_code'
+    else:
+        display_type = 'std::error_condition'
+
+    return [
+        'C_STRUCT',
+        obj['addr'],
+        display_type,
+        ['value', encode_value(value, heap)],
+        ['category', encode_value(category, heap)]
+    ]
+
