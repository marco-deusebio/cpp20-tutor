+def get_std_atomic_summary(obj, heap):
+    if obj.get('kind') != 'struct':
+        return None
+
+    type_name = obj.get('type') or ''
+    if 'atomic<' not in type_name:
+        return None
+
+    value = get_direct_struct_member(obj, '_M_i')
+    if value is None:
+        return None
+
+    args = top_level_template_args(type_name, 'atomic') or []
+    if args:
+        display_type = 'std::atomic<' + display_cpp_type(args[0]) + '>'
+    else:
+        display_type = 'std::atomic'
+
+    return [
+        'C_STRUCT',
+        obj['addr'],
+        display_type,
+        ['value', encode_value(value, heap)]
+    ]
+
