+def get_string_view_characters(ptr, size, heap):
+    if not isinstance(size, (int, long)) or size < 0:
+        return None
+    if size > 256:
+        return None
+
+    deref_val = ptr.get('deref_val')
+    if not deref_val or deref_val.get('kind') != 'heap_block':
+        return None
+
+    start_addr = parse_hex_ptr(ptr.get('val'))
+    if start_addr is None:
+        return None
+
+    characters = ['C_ARRAY', ptr.get('val')]
+    for element in deref_val.get('val') or []:
+        element_addr = parse_hex_ptr(element.get('addr'))
+        if element_addr is None:
+            continue
+        if element_addr < start_addr:
+            continue
+        if element_addr >= start_addr + size:
+            break
+        characters.append(encode_value(element, heap))
+        if len(characters) - 2 >= size:
+            break
+
+    if len(characters) - 2 != size:
+        return None
+
+    return characters
+
+
+def get_std_string_view_summary(obj, heap):
+    if obj.get('kind') != 'struct':
+        return None
+
+    type_name = obj.get('type') or ''
+    if 'basic_string_view<char' not in type_name:
+        return None
+
+    length = get_direct_struct_member(obj, '_M_len')
+    ptr = get_direct_struct_member(obj, '_M_str')
+    if length is None or not ptr or ptr.get('kind') != 'pointer':
+        return None
+
+    ret = [
+        'C_STRUCT',
+        obj['addr'],
+        'std::string_view',
+        ['data', encode_value(ptr, heap)],
+        ['size', encode_value(length, heap)]
+    ]
+
+    characters = get_string_view_characters(ptr, length.get('val'), heap)
+    if characters is not None:
+        ret.append(['characters', characters])
+
+    return ret
+
 
