+def get_reference_wrapper_display_type(type_name):
+    args = top_level_template_args(type_name, 'reference_wrapper') or ['element']
+    return 'std::reference_wrapper<' + display_cpp_type(args[0]) + '>'
+
+
+def get_std_reference_wrapper_summary(obj, heap):
+    if obj.get('kind') != 'struct':
+        return None
+
+    type_name = obj.get('type') or ''
+    if 'reference_wrapper<' not in type_name:
+        return None
+
+    ptr = get_direct_struct_member(obj, '_M_data')
+    if not ptr or ptr.get('kind') != 'pointer':
+        return None
+
+    return [
+        'C_STRUCT',
+        obj['addr'],
+        get_reference_wrapper_display_type(type_name),
+        ['target', encode_value(ptr, heap)]
+    ]
+
