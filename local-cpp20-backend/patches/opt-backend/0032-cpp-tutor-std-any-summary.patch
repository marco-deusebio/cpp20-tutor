+def get_std_any_summary(obj, heap):
+    if obj.get('kind') != 'struct':
+        return None
+
+    type_name = display_cpp_type(obj.get('type') or '')
+    if type_name not in ('any', 'std::any'):
+        return None
+
+    manager = get_direct_struct_member(obj, '_M_manager')
+    if not manager or manager.get('kind') != 'pointer':
+        return None
+
+    manager_value = manager.get('val')
+    parsed_manager = parse_hex_ptr(manager_value)
+    if parsed_manager is None:
+        has_value = manager_value
+    else:
+        has_value = parsed_manager != 0
+
+    return [
+        'C_STRUCT',
+        obj['addr'],
+        'std::any',
+        ['has_value', ['C_DATA', manager.get('addr', obj['addr']), 'bool', has_value]]
+    ]
+
