+def preserve_duplicate_json_keys(pairs):
+    ret = {}
+    seen = {}
+    for key, val in pairs:
+        count = seen.get(key, 0) + 1
+        seen[key] = count
+        if count > 1:
+            key = key + '__dup' + str(count)
+        ret[key] = val
+    return ret
